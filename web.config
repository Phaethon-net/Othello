<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for Othello.

  - Static assets (.css, .js, favicon, fonts) are cached for one year as
    immutable. Combined with the ?v=<filemtime> query string emitted by
    header.php, this means: a fresh push gives every asset a new URL,
    which is a cache miss everywhere (browser, corporate proxy, CDN);
    once fetched it never has to be re-validated.

  - The HTML page itself (index.php and other .php endpoints) is left to
    PHP, which sends Cache-Control: no-cache, no-store, must-revalidate
    from the top of index.php. set_viewer.php / export.php each set
    their own Content-Type / Content-Disposition headers.

  Apache users: this file is ignored. See .htaccess instead.
-->
<configuration>
  <system.webServer>

    <staticContent>
      <!-- 1 year, public, immutable. Applies to every static file IIS
           serves directly out of this folder (CSS, JS, ico, fonts, etc.). -->
      <clientCache cacheControlMode="UseMaxAge"
                   cacheControlMaxAge="365.00:00:00"
                   cacheControlCustom="public, immutable" />
      <!-- Older IIS versions lack woff2 by default; remove+add is idempotent. -->
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Belt-and-suspenders: a couple of basic security headers that
             cost nothing on a closed clinical network and avoid mixed
             warnings if anything is ever proxied. -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy"        value="same-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Block direct download of config / docs / dotfiles. -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".claude" />
          <add segment=".git" />
          <add segment="lib" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".ini" allowed="false" />
          <add fileExtension=".md"  allowed="false" />
          <add fileExtension=".log" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
